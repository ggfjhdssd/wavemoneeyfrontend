{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/",       "dest": "/index.html" },
    { "src": "/play",   "dest": "/play.html"  },
    { "src": "/play/",  "dest": "/play.html"  },
    { "src": "/admin",  "dest": "/admin.html" },
    { "src": "/admin/", "dest": "/admin.html" },
    { "src": "/(.*)",   "dest": "/$1"         }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",              "value": "ALLOWALL" },
        { "key": "Access-Control-Allow-Origin",  "value": "*" }
      ]
    }
  ]
}
